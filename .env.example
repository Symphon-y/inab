# Database
DATABASE_URL=postgresql://inab:inab_dev@localhost:5432/inab_dev

# Production database (used by docker-compose.production.yml)
POSTGRES_USER=inab
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=inab

# Encryption keys for storing API credentials
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-random-encryption-key-at-least-32-chars
ENCRYPTION_SALT=your-random-salt-at-least-32-chars

